{
  "name": "app",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "npm run format -- --check",
    "lint": "npx --node-options='--experimental-strip-types' eslint --flag unstable_native_nodejs_ts_config --max-warnings=0 .",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@tsconfig/strictest": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "husky": "latest",
    "lint-staged": "latest",
    "prettier": "latest",
    "prettier-plugin-organize-imports": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest"
  }
}
